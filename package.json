{
  "name": "specboard",
  "version": "0.1.5",
  "private": true,
  "description": "Lightweight, spec-based product management layer over git-native specs. Open-core self-host + hosted SaaS.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:up": "docker compose -f infra/docker-compose.yml up -d db",
    "db:migrate": "pnpm --filter @specboard/db migrate",
    "db:seed": "pnpm --filter @specboard/db seed",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "turbo": "^2.10.2",
    "typescript": "^5.7.2"
  }
}
